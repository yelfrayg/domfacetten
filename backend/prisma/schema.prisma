generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  artnr       Int     @id @default(autoincrement())
  name        String
  description String
  keywords    Json
  price       Float
  available   Boolean

  images ProductImage[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  urls      Json
  productId Int
  product   Product @relation(fields: [productId], references: [artnr])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  arttype     String
  artnr       Int     @id
  name        String
  description String
  keywords    Json
  price       Decimal
  available   Boolean
  heroImage   String
  image2      String?
  image3      String?
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  arttype     String
  artnr       Int     @id
  name        String
  description String
  keywords    Json
  price       Decimal
  available   Boolean
  heroImage   String
  image2      String?
  image3      String?
  cart        Cart[]
}

model Orders {
  orderId    String   @id @db.Text
  products   Json
  timestamp  DateTime
  customerId String
  user       Users?   @relation(fields: [customerId], references: [userId], onDelete: Cascade)
}

model Codes {
  codeId    String  @id @db.Text
  codeValue Float
  expired   Boolean @default(true)
}

model Users {
  userId     String   @id @default(cuid())
  email      String   @unique
  first_name String   @default("")
  last_name  String   @default("")
  password   String
  address    Json     @default(dbgenerated("'{}'"))
  orders     Orders[] // [] = 1:n relation
  cart       Cart[]
}

model Cart {
  cartId    String  @id @default(cuid())
  userId    String
  user      Users   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [artnr])
  quantity  Int     @default(1)

  @@unique([userId, productId])
}
